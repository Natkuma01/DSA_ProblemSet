{
  "$schema": "vscode://schemas/color-theme",
  "name": "vscode-pets",
  "type": "light",
  "colors": {
    "editor.background": "#FAF8F0",
    "editor.foreground": "#3C3C3C",
    "editorCursor.foreground": "#6A6A6A",
    "editorLineNumber.foreground": "#8A8A8A",
    "activityBar.background": "#3B6E4B",
    "sideBar.background": "#F4F2E7",
    "titleBar.activeBackground": "#4A8F62"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7D8C77",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#B0534E"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#3B6E4B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": {
        "foreground": "#3A6A83"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#AE5D3D"
      }
    }
  ]
}
